# ══════════════════════════════════════════════════════════════
# Verify AI Backend — Environment Configuration Template
# Copy this file to .env and fill in your real values.
# ══════════════════════════════════════════════════════════════

# ── REQUIRED ───────────────────────────────────────────────────
# Google Gemini AI — get one free at https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# ── OPTIONAL: Web Search Grounding ────────────────────────────
# Tavily — best RAG search, 1000 free requests/month
# https://app.tavily.com/
TAVILY_API_KEY=

# Serper — Google Search API, 2500 free queries
# https://serper.dev/
SERPER_API_KEY=

# ── OPTIONAL: Google Maps ──────────────────────────────────────
# For location-aware civic queries
# https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=

# ── MODEL CONFIGURATION ────────────────────────────────────────
GENERATOR_MODEL=gemini-2.5-flash
AUDITOR_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=models/text-embedding-004

# ── SERVER CONFIGURATION ───────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
LOG_LEVEL=INFO

# ── SAFETY CONFIGURATION ──────────────────────────────────────
MAX_RETRIES=2
REQUEST_TIMEOUT=45
SEARCH_MAX_RESULTS=5
ENABLE_SEARCH_GROUNDING=true
ENABLE_MAPS_INTEGRATION=false
ENABLE_MULTI_AUDITOR=true

